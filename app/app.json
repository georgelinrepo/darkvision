{
  "expo": {
    "name": "DarkVision",
    "slug": "darkvision",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111111"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.darkvision.app",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "DarkVision uses speech recognition to capture your chess moves.",
        "NSMicrophoneUsageDescription": "DarkVision uses the microphone to listen for your moves and the wake word."
      }
    },
    "android": {
      "package": "com.darkvision.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111111"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "@react-native-voice/voice",
      "expo-dev-client"
    ]
  }
}
